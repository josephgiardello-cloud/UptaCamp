# Runtime service endpoints
UPTACAMP_ONLINE_URL=http://127.0.0.1:8787
UPTACAMP_ONLINE_WS_URL=ws://127.0.0.1:8790
UPTACAMP_ONLINE_URL_PROD=https://uptacamp-api.onrender.com
